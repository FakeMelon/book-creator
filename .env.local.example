# Database.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"

# OpenRouter — single key for all AI (text + images)
OPENROUTER_API_KEY=""
STORY_MODEL="anthropic/claude-sonnet-4.5"
REVIEW_MODEL="anthropic/claude-sonnet-4.5"
IMAGE_MODEL="black-forest-labs/flux.2-pro"  # or "google/gemini-3.1-flash-image-preview"
IMAGE_SIZE="1K"  # 1K for testing (~$0.81/book), 4K for print (~$3.78/book)

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="book-creator"
R2_PUBLIC_URL=""

# Trigger.dev
TRIGGER_SECRET_KEY=""

# LemonSqueezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_HARDCOVER_VARIANT_ID=""
LEMONSQUEEZY_SOFTCOVER_VARIANT_ID=""

# Lulu
LULU_API_KEY=""
LULU_API_SECRET=""
LULU_SANDBOX="true"

# Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL="books@yourdomain.com"

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo mode — when true, /create works without DB, auth, R2, or Trigger.dev
# Uploads go to tmpdir, story generation runs inline via OpenRouter
NEXT_PUBLIC_DEMO_MODE=true
