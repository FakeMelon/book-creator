generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  referralSource String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  books    Book[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Book Models ───

enum BookStatus {
  DRAFT
  GENERATING
  COVER_READY
  PREVIEW_READY
  APPROVED
  ORDERED
}

enum BookFormat {
  SQUARE_8X8
  LANDSCAPE_8X10
}

enum StoryStyle {
  PROSE
  RHYME
}

enum IllustrationStyle {
  WATERCOLOR_WHIMSY
  BRIGHT_AND_BOLD
  STORYBOOK_CLASSIC
  COZY_AND_WARM
}

enum PageType {
  COVER
  TITLE
  DEDICATION
  ILLUSTRATION
  BACK_COVER
}

model Book {
  id     String     @id @default(cuid())
  userId String
  status BookStatus @default(DRAFT)

  // Child info
  childName   String
  childAge    Int
  childGender String

  // Photo
  childPhotoUrl  String?
  childPhotoKey  String?
  childPhotoKeys String[]

  // Creative inputs
  favoriteThings     String[]
  personalityTraits  String[]
  theme              String
  occasion           String?
  hobbies            String[]
  favoriteCharacters String[]
  favoriteAnimal     String[]

  // Additional characters
  additionalCharacters Json?
  storyStyle       StoryStyle       @default(PROSE)
  illustrationStyle IllustrationStyle @default(WATERCOLOR_WHIMSY)

  // Format
  format    BookFormat @default(SQUARE_8X8)
  pageCount Int        @default(32)

  // Generated content
  title           String?
  storyText       Json?
  characterRefUrl String?
  characterRefKey String?
  coverImageUrl     String?
  coverImageKey     String?
  backCoverImageUrl String?
  backCoverImageKey String?

  // PDFs
  pdfUrl        String?
  pdfKey        String?
  previewPdfUrl String?
  previewPdfKey String?

  // Generation tracking
  generationId        String?
  generationStartedAt DateTime?
  generationCompletedAt DateTime?
  generationError     String?

  // Optional
  dedication String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages          BookPage[]
  orders         Order[]
  generationLogs GenerationLog[]

  @@index([userId])
  @@index([status])
}

model BookPage {
  id         String   @id @default(cuid())
  bookId     String
  pageNumber Int
  type       PageType

  text             String?
  textPosition     String?  @default("bottom")
  illustrationPrompt String?
  illustrationUrl  String?
  illustrationKey  String?

  generationAttempt Int     @default(0)
  isApproved       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, pageNumber])
  @@index([bookId])
}

// ─── Order Models ───

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SUBMITTED_TO_PRINT
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CoverType {
  HARDCOVER
  SOFTCOVER
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  bookId      String
  status      OrderStatus @default(PENDING_PAYMENT)

  // Pricing (in cents)
  subtotal     Int
  shippingCost Int     @default(0)
  tax          Int     @default(0)
  discount     Int     @default(0)
  total        Int
  currency     String  @default("USD")

  // Product
  format   BookFormat
  quantity Int        @default(1)
  coverType CoverType

  // Payment
  lemonSqueezyOrderId    String?
  lemonSqueezyCheckoutUrl String?

  // Fulfillment
  luluOrderId        String?
  luluTrackingUrl    String?
  luluTrackingNumber String?
  luluShippingCarrier String?

  // Shipping address
  shippingName       String
  shippingAddress1   String
  shippingAddress2   String?
  shippingCity       String
  shippingState      String?
  shippingPostalCode String
  shippingCountry    String  @default("US")

  // Timestamps
  paidAt            DateTime?
  submittedToLuluAt DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([bookId])
  @@index([status])
  @@index([lemonSqueezyOrderId])
}

// ─── Generation Tracking ───

enum GenerationStage {
  STORY_GENERATION
  SAFETY_REVIEW
  CHARACTER_DESIGN
  COVER_ILLUSTRATIONS
  PAGE_ILLUSTRATIONS
  PDF_ASSEMBLY
  QUALITY_CHECK
}

enum GenerationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model GenerationLog {
  id     String           @id @default(cuid())
  bookId String
  stage  GenerationStage
  status GenerationStatus @default(PENDING)

  message  String?
  metadata Json?
  error    String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([bookId, stage])
}
